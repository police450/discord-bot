DISCORD_TOKEN=your_discord_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Voice ID — find yours at elevenlabs.io/voice-library
# Default below is "Rachel". Replace with your custom or cloned voice ID.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Model: eleven_turbo_v2_5 (fast) | eleven_multilingual_v2 (best quality)
ELEVENLABS_MODEL=eleven_turbo_v2_5
# Voice settings (0.0 - 1.0)
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY=0.75
ELEVENLABS_STYLE=0.0

# Base44 Dashboard Integration
# Format: https://api.base44.app/api/apps/YOUR_APP_ID
# Find YOUR_APP_ID in your Base44 app URL or Settings → API
DASHBOARD_API_URL=https://api.base44.app/api/apps/YOUR_APP_ID
DASHBOARD_API_KEY=your_base44_api_key

# AI Models
GPT_MODEL=gpt-4.1-mini
STT_MODEL=whisper-1
SYSTEM_PROMPT=You are a real-time voice assistant in a Discord call. Be concise and friendly.

# Behavior
SILENCE_TIMEOUT_MS=1500
MIN_AUDIO_MS=300